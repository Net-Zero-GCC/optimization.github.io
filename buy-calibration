<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Buy License EPCalibration</title>
<style>
  :root {
    --bg:      #05070d;
    --card:    #0d1117;
    --border:  #1e2433;
    --accent:  #3c8dbc;   /* EPCalibration blue */
    --accent2: #f39c12;   /* EPCalibration orange */
    --green:   #22c55e;
    --gold:    #f59e0b;
    --text:    #e2e8f0;
    --muted:   #64748b;
    --radius:  12px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', system-ui, sans-serif;
    min-height: 100vh;
  }

  /* -- Hero -- */
  .hero {
    text-align: center;
    padding: 5rem 1.5rem 3rem;
    max-width: 780px;
    margin: 0 auto;
  }
  .badge-pill {
    display: inline-block;
    background: rgba(60,141,188,.12);
    border: 1px solid rgba(60,141,188,.35);
    color: var(--accent);
    border-radius: 999px;
    padding: .3rem 1rem;
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    letter-spacing: -.03em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }
  h1 span {
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .subtitle {
    color: var(--muted);
    font-size: 1.1rem;
    line-height: 1.6;
    max-width: 560px;
    margin: 0 auto 2.5rem;
  }

  /* -- Pricing grid -- */
  .pricing-wrap {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  @media (max-width: 600px) {
    .pricing-wrap { grid-template-columns: 1fr; }
  }
  .pricing-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 18px;
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .pricing-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
  }
  .pricing-card.popular {
    border-color: var(--gold);
    box-shadow: 0 0 0 1px rgba(245,158,11,.3), 0 8px 32px rgba(245,158,11,.08);
  }
  .pricing-card.popular::before {
    background: linear-gradient(90deg, var(--gold), #f97316);
  }
  .popular-badge {
    position: absolute;
    top: 14px; right: 14px;
    background: var(--gold);
    color: #000;
    font-size: .65rem;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
    border-radius: 999px;
    padding: .2rem .65rem;
  }
  .pricing-top { padding: 2rem 2rem 1.5rem; }
  .plan-name  { font-size: .7rem; font-weight: 700; letter-spacing: .14em; color: var(--muted); text-transform: uppercase; margin-bottom: .5rem; }
  .price      { font-size: 3rem; font-weight: 800; letter-spacing: -.04em; }
  .price sup  { font-size: 1.2rem; vertical-align: super; font-weight: 600; }
  .price sub  { font-size: 1rem; font-weight: 500; color: var(--muted); }
  .price-note { color: var(--muted); font-size: .82rem; margin-top: .3rem; }
  .save-pill  {
    display: inline-block;
    background: rgba(34,197,94,.12);
    border: 1px solid rgba(34,197,94,.3);
    color: var(--green);
    border-radius: 999px;
    padding: .15rem .7rem;
    font-size: .72rem;
    font-weight: 700;
    margin-top: .5rem;
  }
  .divider { border: none; border-top: 1px solid var(--border); margin: 0; }
  .features { padding: 1.5rem 2rem; display: flex; flex-direction: column; gap: .75rem; flex: 1; }
  .feature   { display: flex; gap: .75rem; align-items: flex-start; font-size: .9rem; line-height: 1.4; }
  .check     { color: var(--green); font-size: 1rem; flex-shrink: 0; margin-top: .05rem; }
  .cta-wrap  { padding: 0 2rem 2rem; display: flex; flex-direction: column; gap: .75rem; }

  .paypal-btn {
    background: #ffd140;
    color: #111;
    border: none;
    border-radius: 10px;
    padding: .9rem;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .5rem;
    text-decoration: none;
    transition: opacity .15s, transform .1s;
    font-family: inherit;
  }
  .paypal-btn:hover  { opacity: .9; }
  .paypal-btn:active { transform: scale(.98); }
  .paypal-btn.yearly { background: linear-gradient(135deg, var(--gold), #f97316); color: #000; }
  .paypal-logo { font-size: 1.1rem; }
  .trust-note {
    text-align: center;
    color: var(--muted);
    font-size: .75rem;
    margin-top: .25rem;
  }
  .trust-note a { color: var(--accent); text-decoration: none; }

  /* -- What you get -- */
  .whatyouget {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }
  .wyg-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .9rem;
  }
  @media (max-width: 600px) { .wyg-grid { grid-template-columns: 1fr; } }
  .wyg-item {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.2rem;
    font-size: .85rem;
    line-height: 1.5;
    color: var(--muted);
  }
  .wyg-item b { color: var(--text); display: block; margin-bottom: .2rem; }

  /* -- How it works -- */
  .steps-section {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 1.5rem 5rem;
  }
  .section-title {
    text-align: center;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 2rem;
    letter-spacing: -.02em;
  }
  .steps { display: flex; flex-direction: column; gap: 1rem; }
  .step  {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }
  .step-num {
    width: 32px; height: 32px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .8rem;
    font-weight: 800;
    flex-shrink: 0;
    color: #fff;
  }
  .step-body h3 { font-size: .95rem; font-weight: 600; margin-bottom: .2rem; }
  .step-body p  { font-size: .83rem; color: var(--muted); line-height: 1.5; }

  /* -- FAQ -- */
  .faq-section {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 1.5rem 6rem;
  }
  .faq-item  { border-top: 1px solid var(--border); padding: 1.1rem 0; }
  .faq-q     { font-weight: 600; font-size: .9rem; cursor: pointer; display: flex; justify-content: space-between; }
  .faq-a     { color: var(--muted); font-size: .85rem; line-height: 1.6; margin-top: .6rem; display: none; }
  .faq-a.open{ display: block; }

  footer {
    text-align: center;
    color: var(--muted);
    font-size: .78rem;
    padding: 1.5rem;
    border-top: 1px solid var(--border);
  }
</style>
</head>
